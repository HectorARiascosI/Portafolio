# ─────────────────────────────────────────
# Variables de entorno — copia este archivo
# a .env.local y rellena los valores reales.
# En Vercel: Settings → Environment Variables
# ─────────────────────────────────────────

# EmailJS — formulario de contacto
# Regístrate gratis en https://www.emailjs.com
# 1. Crea un Service (Gmail) → copia el Service ID
# 2. Crea un Template con variables: from_name, from_email, message, reply_to
# 3. Copia el Public Key desde Account → API Keys
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# URL del sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000
